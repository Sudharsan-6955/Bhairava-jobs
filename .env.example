# Example client environment variables for local development / documentation
# Do NOT store secrets here. Copy to `.env.local` and adjust values locally.

# Public API base URL (omit trailing /api — the client resolver will add it if needed)
NEXT_PUBLIC_API_URL=https://bhairava-jobs-backend.onrender.com

# Public app URL (used for building absolute URLs)
NEXT_PUBLIC_APP_URL=https://bhairava-jobs.vercel.app

# Example: feature flags
# NEXT_PUBLIC_FEATURE_X=true
