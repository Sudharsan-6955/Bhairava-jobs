# Frontend environment variables for Vercel / local development
# Set NEXT_PUBLIC_API_URL to your deployed backend API base (Render)
# Example: https://bhairava-jobs-backend.onrender.com/api
NEXT_PUBLIC_API_URL=

# Optional: local backend probe URL used by the runtime resolver during local dev
# Example: http://localhost:5000/api
NEXT_PUBLIC_LOCAL_API_URL=
